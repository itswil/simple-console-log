{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ESNext"],
    "strict": true,
    "rootDir": "src",

    /* tsdown specific adjustments */
    "noEmit": true, // tsdown handles the files; TSC shouldn't output anything
    "sourceMap": true, // Keep this so tsdown can read your maps
    "esModuleInterop": true, // Helps when importing CJS libraries (like 'vscode')
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true, // Speeds up type-checking by skipping node_modules

    /* VS Code Extension specifics */
    "types": ["node", "vscode"] // Ensure TS knows about both environments
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "out", "dist"]
}
