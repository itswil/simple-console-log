{
  "name": "simple-console-log-frog",
  "displayName": "Simple Console Log",
  "description": "The simplest console log shortcut for your JavaScript/TypeScript",
  "version": "1.0.0",
  "publisher": "itswil",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Debuggers",
    "Keymaps",
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "console log",
    "logging",
    "debug",
    "debugging",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "nodejs",
    "astro",
    "react",
    "svelte",
    "vue"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "simpleConsoleLog.log",
        "title": "Simple Console Log: Insert console log"
      }
    ],
    "keybindings": [
      {
        "command": "simpleConsoleLog.log",
        "key": "ctrl+alt+l",
        "when": "editorTextFocus"
      }
    ]
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "repository": {
    "type": "git",
    "url": "https://github.com/itswil/simple-console-log"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.1.0",
    "path": "^0.12.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
