{
  "name": "simple-console-log-frog",
  "displayName": "Simple Console Log for JS/TS",
  "description": "The simplest console log shortcut for your JavaScript/TypeScript",
  "version": "1.0.1",
  "type": "module",
  "publisher": "itswil",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Debuggers",
    "Keymaps",
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "console log",
    "logging",
    "debug",
    "debugging",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "nodejs",
    "astro",
    "react",
    "svelte",
    "vue"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "main": "./dist/extension.cjs",
  "contributes": {
    "commands": [
      {
        "command": "simpleConsoleLog.log",
        "title": "Simple Console Log: Insert console log"
      }
    ],
    "keybindings": [
      {
        "command": "simpleConsoleLog.log",
        "key": "ctrl+alt+l",
        "when": "editorTextFocus"
      }
    ]
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "repository": {
    "type": "git",
    "url": "https://github.com/itswil/simple-console-log"
  },
  "scripts": {
    "compile": "tsdown",
    "watch": "tsdown --watch",
    "fmt": "oxfmt --check",
    "fmt:fix": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "pretest": "pnpm compile && pnpm lint:fix",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "path": "^0.12.7",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3"
  }
}
